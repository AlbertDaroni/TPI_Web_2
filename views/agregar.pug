extends layout 

block content 
    h4 Crear una publicación 
    form(action="/publicacion/agregar", method="post", enctype="multipart/form-data") 
        label(for="titulo") Título 
        input(type="text", name="titulo", required)
        br
        label(for="descripcion") Descripción
        br
        textarea(name="descripcion", cols="50", rows="5") 
        br
        label(for="imagen") Imagen
        input(type="file", name="imagen", required)
        br
        label(for="licencia") Licencia 
        input(type="radio", name="licencia", value=true)
        small Sí
        input(type="radio", name="licencia", value=false)
        small No 
        br
        if (seguidos && seguidos.length > 0)
            label Etiquetar
            div.lista-seguidos
                each seguido in seguidos 
                    div.usuario-etiqueta
                        img(src=seguido.foto_perfil || "/images/sin_foto_perfil.png", width="40")
                        h5= seguido.nombre
                        input(type="checkbox", name="etiquetados", value=seguido.id)
        button(type="submit") Crear