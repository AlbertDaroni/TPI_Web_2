extends layout

block content
  div#contenido
    if datos && datos.length > 0
      each dato in datos 
        div.publicacion(id=`pub-${dato.publicacion.id}`)
          .perfil-header(onclick=`location.href='/perfil/usuario/${dato.usuario.id}'`)
            img(src=dato.usuario.foto_perfil || "/images/sin_foto_perfil.png", width="40")
            h5= dato.usuario.nombre

          each imagen in dato.imagenes
            img.main-img(src=imagen.imagen || "/images/sin_imagen.png")

          div#informacion
            h5= dato.publicacion.titulo
            p= dato.publicacion.fecha.toLocaleDateString()
            p= dato.publicacion.descripcion

          div#acciones
            if (!esMiPerfil)
              button(onclick=`actualizarLikes(${dato.publicacion.id})`) ❤️
                span(id=`likes-pub-${dato.publicacion.id}`)= dato.publicacion.likes
              button(onclick=`alternarComentarios(${dato.publicacion.id}, ${JSON.stringify(dato.comentarios)})`) 💬
                span(id=`comentarios-pub-${dato.publicacion.id}`)= dato.cantidad
            else
              button(type="button") ❤️
                span(id=`likes-pub-${dato.publicacion.id}`)= dato.publicacion.likes
              button(onclick=`alternarComentarios(${dato.publicacion.id}, ${JSON.stringify(dato.comentarios)})`) 💬
                span(id=`comentarios-pub-${dato.publicacion.id}`)= dato.cantidad

            button(onclick=`marcarInteres(${dato.publicacion.id})`) ⭐
            a(href=`/publicacion/${dato.publicacion.id}/denunciar`) 🚩
          
          div.form-comentario
            input(type="text", id=`input-coment-${dato.publicacion.id}`, placeholder="Escribí un comentario...")
            button(onclick=`agregarComentario(${dato.publicacion.id})`) Comentar 

          div(id=`lista-comentarios-${dato.publicacion.id}`)
    else
      p No hay publicaciones disponibles

  script.
    // ACTUALIZAR LIKES
    async function actualizarLikes(id) {
      const res = await fetch(`/publicacion/${id}/like`, { method: 'POST' });
      const data = await res.json();
      document.getElementById(`likes-pub-${id}`).innerText = data.likes;
    }

    // MOSTRAR / OCULTAR COMENTARIOS
    function alternarComentarios(id, comentarios) {
      const contenedor_comentarios = document.getElementById(`lista-comentarios-${id}`);

      if (contenedor_comentarios.style.display === 'none') {
        contenedor_comentarios.innerHTML = '';

        comentarios.forEach(comentario => {
          contenedor_comentarios.innerHTML += `
            <img src="${comentario.id_usuario.foto_perfil}" alt="/images/sin_foto_perfil.png" width="40">
            <h5>${comentario.id_usuario.nombre}</h5>
            <p>${comentario.comentario}</p>
          `;

          contenedor_comentarios.appendChild(divComentario);
        });
        contenedor_comentarios.style.display = 'block';
      } else {
        contenedor_comentarios.style.display = 'none';
      }
    }

    // AGREGAR COMENTARIO
    async function agregarComentario(id) {
      const texto = document.querySelector(`input-coment-${id}`).value;
      if (!texto) return;

      try {
        const res = await fetch(`/publicacion/${id}/comentario/agregar`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ comentario: texto, id_usuario: usuario.id })
        });

        if (res.ok) location.reload();
      } catch (error) { console.error('Error al agregar el comentario', error); }
