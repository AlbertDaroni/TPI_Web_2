extends layout 

block estilo 
    link(rel="stylesheet", href="/stylesheets/denuncia.css")

block content 
    div#contenido
        h3 Reportar un problema
        p Por favor, describí el motivo de tu denuncia.
        
        if (id_publicacion)
            form(action=`/publicacion/${id_publicacion}/denunciar`, method="post") 
                label(for="descripcion") Motivo de la denuncia
                textarea(name="descripcion", placeholder="¿Por qué quieres reportar esta publicación?", required) 
                button(type="submit") Enviar reporte
        else if (id_comentario)
            form(action=`/publicacion/comentario/${id_comentario}/denunciar`, method="post") 
                label(for="descripcion") Motivo de la denuncia
                textarea(name="descripcion", placeholder="¿Por qué quieres reportar este comentario?", required) 
                button(type="submit") Enviar reporte
        else
            p No se ha encontrado el objeto a denunciar