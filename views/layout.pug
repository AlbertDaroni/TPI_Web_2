doctype html
html
  head
    title Instragram Trucho
    link(rel='stylesheet', href='/stylesheets/global.css')
    block estilo
  body
    block content
    
    block footer
      footer
        nav 
          button#button-buscador(onclick="alternarBuscador()") 🔎
          form#form-busqueda(action="/buscar", method="get", style="display: none;")
            input#input-buscador(type="text", name="nombre", placeholder="Ingresá el nombre...")
          a(href="/publicacion/agregar") ➕
          a(href="/") 🏠
          a(href="/usuario/notificaciones") ✉️
          a(href=`/usuario/${userIdSesion}/perfil`) 👤

    script.
      function alternarBuscador() {
        const form_busqueda = document.getElementById('form-busqueda');
        const button_buscador = document.getElementById('button-buscador');
        form_busqueda.style.display = (form_busqueda.style.display === 'none') ? 'inline-block' : 'none';
      }